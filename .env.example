# Copy to .env and fill in. Bun auto-loads .env for `bun run` and `bunx`.
NODE_ENV=development

# Postgres connection string. Matches docker-compose.yml below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/home

# Better Auth — generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Used by the browser auth client.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set both to enable Google sign-in.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
