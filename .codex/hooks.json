{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo_root/.codex/hooks/prune-plans.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo_root/.codex/hooks/format.sh\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
